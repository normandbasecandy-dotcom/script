task.wait(1)

local StarterGui = game:GetService("StarterGui")
local found = false

local function notify(text)
    StarterGui:SetCore("SendNotification", {
        Title = "normand",
        Text = text,
        Duration = 5
    })
end

local function change(v)
    if v:IsA("TextLabel") then
        
        if v.Text == "Mytique" or v.Text == "mytique" then
            found = true
            
            v.Text = "OG"
            v.TextColor3 = Color3.fromRGB(255,221,85)

            local stroke = Instance.new("UIStroke")
            stroke.Thickness = 2
            stroke.Color = Color3.new(0,0,0)
            stroke.Parent = v
        end

        if v.Text == "$2.5M" or v.Text == "$2.5m" then
            v.Text = "$750B"
        end
        
    end
end

for _,v in pairs(game:GetDescendants()) do
    change(v)
end

game.DescendantAdded:Connect(change)

task.wait(1)

if found then
    notify("Lucky Block modifié")
else
    notify("Aucun bloc mytique trouvé")
end
