-- OPENSOURCE

task.wait(1)
local StarterGui = game:GetService("StarterGui")
local foundLuckyBlock = false

local function notify(text)
    StarterGui:SetCore("SendNotification", {
        Title = "normand",
        Text = text .. " | normand",
        Duration = 5
    })
end

local function isLuckyBlock(display)
    if not display or not display:IsA("TextLabel") then
        return false
    end
    
    local txt = string.lower(display.Text)
    return string.find(txt,"lucky") or string.find(txt,"bloc")
end

local function changeText(v)
    if v:IsA("TextLabel") then
        local parent = v.Parent
        if not parent then return end
        
        local display = parent:FindFirstChild("DisplayName")

        if isLuckyBlock(display) then
            foundLuckyBlock = true

            -- texte OG
            v.Text = "OG"
            v.TextColor3 = Color3.fromRGB(255,221,85)

            if not v:FindFirstChildOfClass("UIStroke") then
                local stroke = Instance.new("UIStroke")
                stroke.Color = Color3.fromRGB(0,0,0)
                stroke.Thickness = 2
                stroke.Parent = v
            end

            local gradient = v:FindFirstChildOfClass("UIGradient")
            if gradient then
                gradient.Color = ColorSequence.new{
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(255,221,85)),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(255,170,0))
                }
            end

            -- prix fake
            if string.find(v.Text,"$") then
                v.Text = "$750B"
            end
        end
    end
end

for _,v in pairs(game:GetDescendants()) do
    changeText(v)
end

game.DescendantAdded:Connect(changeText)

task.wait(1)

if foundLuckyBlock then
    notify("Successfully Injected Lucky Blocks")
else
    notify("No Lucky Blocks Found")
end
end

for _,v in pairs(game:GetDescendants()) do
    change(v)
end

game.DescendantAdded:Connect(change)

task.wait(1)

if found then
    notify("Lucky Block modifié")
else
    notify("Aucun bloc mytique trouvé")
end
